# VHS tape file — generates the README GIF
# Install: brew install vhs
# Run: cd ~/Projects/agentloops && vhs demo.tape

Output demo.gif

Set FontSize 12
Set Width 1000
Set Height 1400
Set Theme "Builtin Dark"
Set Padding 15
Set TypingSpeed 40ms

Type "python3 examples/quickstart/main.py"
Enter
Sleep 4s
Screenshot demo.png
